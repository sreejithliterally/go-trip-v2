{
  "name": "gotripv2",
  "version": "1.0.0",
  "description": "Multi-vendor travel booking platform API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:migrate": "node src/db/migrate.js",
    "db:seed-amenities": "node src/db/seed-amenities.js",
    "db:schema": "psql $DATABASE_URL -f booking_schema.sql",
    "db:ota-schema": "psql $DATABASE_URL -f ota_channel_sync_schema.sql"
  },
  "keywords": [
    "travel",
    "booking",
    "hotels",
    "glamping",
    "activities"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "date-fns": "^3.0.0",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-rate-limit": "^7.0.0",
    "express-validator": "^7.0.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.0",
    "nodemailer": "^9.0.1",
    "pg": "^8.11.0",
    "pg-hstore": "^2.3.4",
    "razorpay": "^2.9.0",
    "sequelize": "^6.37.8",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
